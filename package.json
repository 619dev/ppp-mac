{
  "name": "paperphone-plus-desktop",
  "private": true,
  "license": "AGPL-3.0-only",
  "version": "1.0.7",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:electron": "tsc -p tsconfig.electron.json && mv dist-electron/main.js dist-electron/main.cjs && mv dist-electron/preload.js dist-electron/preload.cjs",
    "build:renderer": "vite build",
    "build": "npm run build:electron && npm run build:renderer",
    "build:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview"
  },
  "dependencies": {
    "crystals-kyber-js": "^2.7.0",
    "electron-store": "^10.0.0",
    "jsqr": "^1.4.0",
    "libsodium-wrappers-sumo": "^0.7.15",
    "lottie-web": "^5.13.0",
    "lucide-react": "^1.8.0",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
